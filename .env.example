# Application
# DATABASE_URL=sqlite+aiosqlite:///./data/webhook.db
# QUEUE_MAX_SIZE=1000
# WORKER_COUNT=4

# LLM: use "groq" for real API (set GROQ_API_KEY) or "mock" for tests/local
LLM_PROVIDER=groq
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# DEBUG=false

# Mock provider (only when LLM_PROVIDER=mock)
# MOCK_LLM_LATENCY_MS=50
# MOCK_LLM_ERROR_RATE=0.0
# MOCK_LLM_MALFORMED_RATE=0.0

# Extraction
# MAX_EXTRACTION_ATTEMPTS=3
